---
import type { Lang } from '@/i18n/utils';
import { localePath } from '@/i18n/utils';
import type { SectionContent } from '@/lib/content';

interface Props {
  lang?: Lang;
  cms?: SectionContent;
}

const { lang = 'de', cms } = Astro.props;

const badge = cms?.badge;
const titlePart1 = cms?.titlePart1;
const titlePart2 = cms?.titlePart2;
const titlePart3 = cms?.titlePart3;
const titlePart4 = cms?.titlePart4;
const description = cms?.description;
const ctaPrimary = cms?.ctaPrimary;
const ctaSecondary = cms?.ctaSecondary;
---

<section class="relative overflow-hidden bg-white min-h-screen flex items-center justify-center pt-20">
  <div class="absolute inset-0 -z-10 h-full w-full overflow-hidden opacity-30 pointer-events-none">
    <div class="glass-node absolute top-1/4 right-1/4 h-32 w-32 rounded-full"></div>
    <div class="glass-node absolute bottom-1/4 left-1/4 h-24 w-24 rounded-full"></div>
    <div class="glass-node absolute top-1/2 right-10 h-16 w-16 rounded-full"></div>
  </div>

  <div class="relative z-10 w-full max-w-4xl px-6 py-16 mx-auto text-center flex flex-col items-center justify-center">
    <div class="w-full flex flex-col items-center">
      <div
        data-animate
        class="inline-block px-4 py-2 border border-primary/20 rounded-full bg-primary/5 text-primary text-xs font-bold tracking-widest uppercase mb-8"
      >
        {badge}
      </div>
      <h1
        data-animate
        data-animate-delay="1"
        class="text-[clamp(2.4rem,6vw,4.5rem)] font-normal text-slate-900 mb-7"
      >
        {titlePart1}<span class="text-transparent bg-clip-text bridge-gradient">{titlePart2}</span>
        <br class="hidden sm:block" />
        {titlePart3}<span class="text-transparent bg-clip-text bridge-gradient">{titlePart4}</span>
      </h1>
      <p
        data-animate
        data-animate-delay="2"
        class="mt-6 text-lg md:text-xl font-normal text-slate-600 leading-relaxed max-w-2xl text-center"
      >
        {description}
      </p>
      <div
        data-animate
        data-animate-delay="3"
        class="flex flex-col sm:flex-row gap-4 mt-10 w-full sm:w-auto justify-center"
      >
        <a href={localePath('/kontakt', lang)} class="w-full sm:w-auto">
          <button class="rounded-xl font-bold transition-all shadow-lg flex items-center justify-center gap-2 bridge-gradient text-white shadow-primary/20 px-8 py-4 text-base w-full">
            {ctaPrimary}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </a>
        <a href={localePath('/philosophie', lang)} class="w-full sm:w-auto">
          <button class="rounded-xl font-bold transition-all shadow-lg flex items-center justify-center gap-2 bg-slate-900 text-white shadow-none hover:bg-slate-800 px-8 py-4 text-base w-full">
            {ctaSecondary}
          </button>
        </a>
      </div>
    </div>
  </div>
</section>
