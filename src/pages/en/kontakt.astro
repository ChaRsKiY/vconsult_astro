---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { ContactForm } from '@/components/ContactForm';
import { useTranslations } from '@/i18n/utils';
import { fetchContent } from '@/lib/content';
import type { SectionContent } from '@/lib/content';

const lang = 'en' as const;
const t = useTranslations(lang);
const cms = await fetchContent(lang);
const c: SectionContent = cms.kontakt ?? {};
const footer = cms.footer ?? {};

const title                  = c.title                  ?? t.kontakt.title;
const description            = c.description            ?? t.kontakt.description;
const breadcrumb             = c.breadcrumb             ?? t.kontakt.breadcrumb;
const heading                = c.heading                ?? t.kontakt.heading;
const subheading             = c.subheading             ?? t.kontakt.subheading;
const addressTitle           = c.addressTitle           ?? t.kontakt.addressTitle;
const addressLine1           = c.addressLine1           ?? t.kontakt.addressLine1;
const addressLine2           = c.addressLine2           ?? t.kontakt.addressLine2;
const phoneTitle             = c.phoneTitle             ?? t.kontakt.phoneTitle;
const emailTitle             = c.emailTitle             ?? t.kontakt.emailTitle;
const formTitle              = c.formTitle              ?? t.kontakt.formTitle;
const firstNameLabel         = c.firstNameLabel         ?? t.kontakt.firstNameLabel;
const firstNamePlaceholder   = c.firstNamePlaceholder   ?? t.kontakt.firstNamePlaceholder;
const lastNameLabel          = c.lastNameLabel          ?? t.kontakt.lastNameLabel;
const lastNamePlaceholder    = c.lastNamePlaceholder    ?? t.kontakt.lastNamePlaceholder;
const emailLabel             = c.emailLabel             ?? t.kontakt.emailLabel;
const emailPlaceholder       = c.emailPlaceholder       ?? t.kontakt.emailPlaceholder;
const messageLabel           = c.messageLabel           ?? t.kontakt.messageLabel;
const messagePlaceholder     = c.messagePlaceholder     ?? t.kontakt.messagePlaceholder;
const submitBtn              = c.submitBtn              ?? t.kontakt.submitBtn;
---

<BaseLayout title={t.meta.kontaktTitle} description={t.meta.kontaktDescription} lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title={title}
      description={description}
      breadcrumbs={[{ label: breadcrumb }]}
      lang={lang}
    />

    <section class="py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="space-y-12">
          <div>
            <h2 class="text-3xl font-normal text-slate-900 mb-4">{heading}</h2>
            <p class="text-slate-600">{subheading}</p>
          </div>
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h4 class="text-lg font-normal text-slate-900">{addressTitle}</h4>
                <p class="mt-2 text-slate-600">{addressLine1}<br />{addressLine2}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.97 3.4 2 2 0 0 1 3.96 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h4 class="text-lg font-normal text-slate-900">{phoneTitle}</h4>
                <p class="mt-2 text-slate-600">+43 664 533 21 64</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h4 class="text-lg font-normal text-slate-900">{emailTitle}</h4>
                <a href="mailto:office@vconsult.at" class="mt-2 text-primary hover:underline font-medium inline-block">office@vconsult.at</a>
              </div>
            </div>
          </div>
        </div>

        <ContactForm
          client:load
          lang={lang}
          formTitle={formTitle}
          firstNameLabel={firstNameLabel}
          firstNamePlaceholder={firstNamePlaceholder}
          lastNameLabel={lastNameLabel}
          lastNamePlaceholder={lastNamePlaceholder}
          emailLabel={emailLabel}
          emailPlaceholder={emailPlaceholder}
          messageLabel={messageLabel}
          messagePlaceholder={messagePlaceholder}
          submitBtn={submitBtn}
        />
      </div>
    </section>

    <section class="h-[500px] w-full bg-slate-200 relative overflow-hidden">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2664.0850772091763!2d16.556272315648835!3d48.11822897922258!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476d079aa803ec27%3A0x6d9f0ab0c2e33f67!2sAirportCity%20Space!5e0!3m2!1sen!2sat!4v1700000000000!5m2!1sen!2sat"
        class="absolute inset-0 w-full h-full border-0 grayscale-[50%]"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="vconsult Google Maps"
      ></iframe>
    </section>
  </main>
  <Footer lang={lang} cms={footer} />
</BaseLayout>
