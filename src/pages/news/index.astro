---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import { NewsList } from "@/components/sections/NewsList";
---

<BaseLayout
  title="News & Einblicke - vconsult"
  description="Bleiben Sie informiert über aktuelle Entwicklungen in der SAP Logistik, S/4HANA und unsere Projekte."
>
  <Navbar currentPath={Astro.url.pathname} />
  <main>
    <PageHeader
      title="News & Einblicke"
      description="Bleiben Sie informiert über aktuelle Entwicklungen in der SAP Logistik, S/4HANA und unsere Projekte."
      breadcrumbs={[{ label: "News" }]}
    />
    <NewsList client:load />
  </main>
  <Footer />
</BaseLayout>
