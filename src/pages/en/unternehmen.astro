---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { useTranslations, localePath } from '@/i18n/utils';
import { fetchContent } from '@/lib/content';
import type { SectionContent } from '@/lib/content';

const lang = 'en' as const;
const t = useTranslations(lang);
const cms = await fetchContent(lang);
const c: SectionContent = cms.unternehmen ?? {};
const footer = cms.footer ?? {};

const title             = c.title             ?? t.unternehmen.title;
const description       = c.description       ?? t.unternehmen.description;
const breadcrumb        = c.breadcrumb        ?? t.unternehmen.breadcrumb;
const vconsultLabel     = c.vconsultLabel     ?? t.unternehmen.vconsultLabel;
const companyTitle      = c.companyTitle      ?? t.unternehmen.companyTitle;
const p1                = c.p1                ?? t.unternehmen.p1;
const p2                = c.p2                ?? t.unternehmen.p2;
const p3                = c.p3                ?? t.unternehmen.p3;
const p3Model           = c.p3Model           ?? t.unternehmen.p3Model;
const p3Rest            = c.p3Rest            ?? t.unternehmen.p3Rest;
const expertTitle       = c.expertTitle       ?? t.unternehmen.expertTitle;
const expertDesc        = c.expertDesc        ?? t.unternehmen.expertDesc;
const sapTeamTitle      = c.sapTeamTitle      ?? t.unternehmen.sapTeamTitle;
const sapTeamDesc       = c.sapTeamDesc       ?? t.unternehmen.sapTeamDesc;
const sapTeamBrand      = c.sapTeamBrand      ?? t.unternehmen.sapTeamBrand;
const sapTeamRest       = c.sapTeamRest       ?? t.unternehmen.sapTeamRest;
const philosophieTitle  = c.philosophieTitle  ?? t.unternehmen.philosophieTitle;
const philosophieSub    = c.philosophieSubtitle ?? t.unternehmen.philosophieSubtitle;
const card1Title        = c.card1Title        ?? t.unternehmen.card1Title;
const card1Desc         = c.card1Desc         ?? t.unternehmen.card1Desc;
const card1Feature1     = c.card1Feature1     ?? t.unternehmen.card1Feature1;
const card1Feature2     = c.card1Feature2     ?? t.unternehmen.card1Feature2;
const card2Title        = c.card2Title        ?? t.unternehmen.card2Title;
const card2Desc         = c.card2Desc         ?? t.unternehmen.card2Desc;
const card2Highlight    = c.card2Highlight    ?? t.unternehmen.card2Highlight;
const ctaText           = c.ctaText           ?? t.unternehmen.ctaText;
const ctaKunden         = c.ctaKunden         ?? t.unternehmen.ctaKunden;
const ctaKontakt        = c.ctaKontakt        ?? t.unternehmen.ctaKontakt;
---

<BaseLayout title={t.meta.unternehmenTitle} description={t.meta.unternehmenDescription} lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title={title}
      description={description}
      breadcrumbs={[{ label: breadcrumb }]}
      lang={lang}
    />

    <!-- Company Overview -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <div data-animate>
            <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">{vconsultLabel}</p>
            <h2 class="text-4xl font-normal tracking-tight text-slate-900 mb-8">{companyTitle}</h2>
            <div class="space-y-5 text-slate-600 leading-relaxed">
              <p>{p1}</p>
              <p>{p2}</p>
              <p>{p3} <em class="not-italic font-medium text-slate-800">{p3Model}</em> {p3Rest}</p>
            </div>
          </div>
          <div data-animate data-animate-delay="1" class="flex flex-col gap-5">
            <div class="rounded-3xl border border-border-light bg-neutral-soft p-8">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white shadow-sm text-primary mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <h3 class="text-xl font-normal text-slate-900 mb-3">{expertTitle}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{expertDesc}</p>
            </div>
            <div class="rounded-3xl border border-border-light bg-neutral-soft p-8">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white shadow-sm text-primary mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              </div>
              <h3 class="text-xl font-normal text-slate-900 mb-3">{sapTeamTitle}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{sapTeamDesc} <span class="font-semibold text-slate-800">{sapTeamBrand}</span> {sapTeamRest}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Berater Philosophie -->
    <section class="py-24 bg-neutral-soft border-t border-border-light">
      <div class="max-w-7xl mx-auto px-6">
        <div data-animate class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-normal tracking-tight text-slate-900 mb-4">{philosophieTitle}</h2>
          <p class="text-lg text-slate-600">{philosophieSub}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div data-animate class="rounded-3xl border border-border-light bg-white p-10 flex flex-col gap-6">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/8 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m16 11 2 2 4-4"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-normal text-slate-900 mb-3">{card1Title}</h3>
              <p class="text-slate-600 leading-relaxed mb-5">{card1Desc}</p>
              <ul class="space-y-2.5">
                <li class="flex items-center gap-2.5 text-sm text-slate-700">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  {card1Feature1}
                </li>
                <li class="flex items-center gap-2.5 text-sm text-slate-700">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  {card1Feature2}
                </li>
              </ul>
            </div>
          </div>
          <div data-animate data-animate-delay="1" class="rounded-3xl border border-border-light bg-white p-10 flex flex-col gap-6">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/8 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-normal text-slate-900 mb-3">{card2Title}</h3>
              <p class="text-slate-600 leading-relaxed mb-5">{card2Desc}</p>
              <div class="rounded-xl bg-primary/8 px-5 py-4">
                <p class="text-sm text-primary font-medium leading-relaxed">{card2Highlight}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-white border-t border-border-light">
      <div data-animate class="max-w-3xl mx-auto px-6 text-center">
        <div class="inline-block w-10 h-0.5 bg-primary mb-8"></div>
        <p class="text-2xl font-normal text-slate-900 leading-relaxed mb-10">{ctaText}</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={localePath('/kunden', lang)} class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 bg-slate-900 text-white font-bold text-sm hover:bg-slate-800 transition-colors">
            {ctaKunden}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={localePath('/kontakt', lang)} class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 border border-primary text-primary font-bold text-sm hover:bg-primary/5 transition-colors">
            {ctaKontakt}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} cms={footer} />
</BaseLayout>
