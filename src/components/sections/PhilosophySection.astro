---
import type { Lang } from '@/i18n/utils';
import type { SectionContent } from '@/lib/content';

interface Props {
  lang?: Lang;
  cms?: SectionContent;
}

const { cms } = Astro.props;

const title = cms?.title;
const subtitle = cms?.subtitle;
const step1Title = cms?.step1Title;
const step1Desc = cms?.step1Desc;
const step2Title = cms?.step2Title;
const step2Desc = cms?.step2Desc;
const step3Title = cms?.step3Title;
const step3Desc = cms?.step3Desc;
---

<section class="py-32 bg-white relative" id="philosophy">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 data-animate class="text-4xl font-normal text-slate-900 mb-6 tracking-tight">
        {title}
      </h2>
      <p data-animate data-animate-delay="1" class="text-slate-600 font-normal leading-relaxed">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative">
      <div data-animate class="relative z-10 flex flex-col items-center p-8 group">
        <div class="h-16 w-16 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-primary/20 transition-all duration-500 bg-neutral-soft">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-normal text-slate-900 mb-3 tracking-tight">{step1Title}</h3>
          <p class="text-slate-600 font-normal leading-relaxed">{step1Desc}</p>
        </div>
      </div>

      <div data-animate data-animate-delay="1" class="relative z-10 flex flex-col items-center p-8 group">
        <div class="h-28 w-28 rounded-3xl bridge-gradient flex items-center justify-center mb-8 shadow-[0_0_50px_rgba(242,146,2,0.3)] transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9a2 2 0 0 0-2 2v2c0 1.1.9 2 2 2h4"/><path d="M20 9a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-4"/><path d="M12 4v16"/><path d="M8 4h8"/><path d="M8 20h8"/></svg>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-normal text-slate-900 mb-3 tracking-tight">{step2Title}</h3>
          <p class="text-slate-600 font-normal leading-relaxed">{step2Desc}</p>
        </div>
      </div>

      <div data-animate data-animate-delay="2" class="relative z-10 flex flex-col items-center p-8 group">
        <div class="h-16 w-16 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-primary/20 transition-all duration-500 bg-neutral-soft">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-normal text-slate-900 mb-3 tracking-tight">{step3Title}</h3>
          <p class="text-slate-600 font-normal leading-relaxed">{step3Desc}</p>
        </div>
      </div>
    </div>
  </div>
</section>
