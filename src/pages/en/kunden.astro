---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { fetchContent, fetchKunden, type SectionContent } from '@/lib/content';

const lang = 'en' as const;
const [cms, alle] = await Promise.all([fetchContent(lang), fetchKunden()]);
const c: SectionContent = cms.kunden ?? {};
const footer = cms.footer ?? {};

const title       = c.title;
const description = c.description;
const breadcrumb  = c.breadcrumb;
const kundenLabel  = c.kundenLabel;
const partnerLabel = c.partnerLabel;

const kunden   = alle.filter(k => k.type === 'kunde');
const partners = alle.filter(k => k.type === 'partner');
---

<BaseLayout title="Our Clients & Partners - vconsult" description="We pool specific expertise and make it available to our clients worldwide." lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title={title}
      description={description}
      breadcrumbs={[{ label: breadcrumb }]}
      lang={lang}
    />

    <!-- Clients -->
    {kunden.length > 0 && (
      <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-12">{kundenLabel}</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {kunden.map((kunde, i) => (
              <a
                href={kunde.website_url ?? undefined}
                target={kunde.website_url ? '_blank' : undefined}
                rel={kunde.website_url ? 'noopener noreferrer' : undefined}
                data-animate
                data-animate-delay={String(Math.min(i, 6))}
                class:list={[
                  'group flex flex-col items-center justify-center gap-4 p-8 rounded-2xl border border-border-light bg-neutral-soft transition-all duration-300',
                  kunde.website_url ? 'hover:shadow-xl hover:border-primary/25 hover:-translate-y-0.5 cursor-pointer' : 'cursor-default',
                ]}
              >
                {kunde.logo_url ? (
                  <img
                    src={kunde.logo_url}
                    alt={kunde.name}
                    loading="lazy"
                    class="h-20 w-full object-contain grayscale group-hover:grayscale-0 transition-all duration-300"
                  />
                ) : (
                  <span class="text-base font-semibold text-slate-500 text-center leading-snug">{kunde.name}</span>
                )}
                {kunde.logo_url && (
                  <span class="text-xs text-slate-400 text-center leading-tight group-hover:text-slate-600 transition-colors">{kunde.name}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Partners -->
    {partners.length > 0 && (
      <section class:list={['py-24 border-t border-border-light', kunden.length > 0 ? 'bg-neutral-soft' : 'bg-white']}>
        <div class="max-w-7xl mx-auto px-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-12">{partnerLabel}</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {partners.map((partner, i) => (
              <a
                href={partner.website_url ?? undefined}
                target={partner.website_url ? '_blank' : undefined}
                rel={partner.website_url ? 'noopener noreferrer' : undefined}
                data-animate
                data-animate-delay={String(Math.min(i, 6))}
                class:list={[
                  'group flex flex-col items-center justify-center gap-4 p-8 rounded-2xl border border-border-light bg-white transition-all duration-300',
                  partner.website_url ? 'hover:shadow-xl hover:border-primary/25 hover:-translate-y-0.5 cursor-pointer' : 'cursor-default',
                ]}
              >
                {partner.logo_url ? (
                  <img
                    src={partner.logo_url}
                    alt={partner.name}
                    loading="lazy"
                    class="h-20 w-full object-contain grayscale group-hover:grayscale-0 opacity-70 group-hover:opacity-100 transition-all duration-300"
                  />
                ) : (
                  <span class="text-base font-semibold text-slate-400 text-center group-hover:text-primary transition-colors">{partner.name}</span>
                )}
                {partner.logo_url && (
                  <span class="text-xs text-slate-400 text-center leading-tight group-hover:text-slate-600 transition-colors">{partner.name}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer lang={lang} cms={footer} />
</BaseLayout>
