---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import { NewsList } from "@/components/sections/NewsList";
import { useTranslations } from "@/i18n/utils";
import { fetchArticles, fetchContent } from "@/lib/content";

const lang = 'en' as const;
const t = useTranslations(lang);

const [articles, cms] = await Promise.all([
  fetchArticles(),
  fetchContent(lang),
]);
---

<BaseLayout title="News & Insights - vconsult" description="Stay informed about the latest developments in SAP logistics, S/4HANA and our projects." lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title="News & Insights"
      description="Stay informed about the latest developments in SAP logistics, S/4HANA and our projects."
      breadcrumbs={[{ label: "News" }]}
      lang={lang}
    />
    <NewsList client:load lang={lang} translations={t.blog} articles={articles} />
  </main>
  <Footer lang={lang} cms={cms.footer} />
</BaseLayout>
