---
const competencies = [
  { title: 'SAP MM', description: 'Transparente Abbildung kompletter interner und externer Beschaffungsprozesse von Materialien und Dienstleistungen inklusive Bedarfsermittlung und Integration zur Finanz.' },
  { title: 'SAP EWM', description: 'Flexible automatisierte Unterstützung bei der Abwicklung sämtlicher Warenbewegungen und der Verwaltung der Bestände in Ihrem Lagerkomplex.' },
  { title: 'SAP WMS', description: 'Flexible automatisierte Unterstützung bei der Abwicklung sämtlicher Warenbewegungen und der Verwaltung der Bestände in Ihrem Lagerkomplex.' },
  { title: 'SAP PP', description: 'Effiziente Gestaltung Ihrer Produktionsplanungs-, Produktionsdurchführungs-Prozesse und Kontroll-Prozesse.' },
  { title: 'SAP SD', description: 'Abbildung aller zum Vertrieb von Produkten oder Dienstleistung gehörenden operativen Prozesse.' },
  { title: 'SAP S/4HANA', description: 'Die ERP-Business-Suite der nächsten Generation auf Basis der leistungsfähigen In-Memory-Technologie.' },
  { title: 'SAP SRM', description: 'Innovative Methoden zur Koordination der Geschäftsprozesse mit Schlüssellieferanten zur Steigerung der Effizienz.' },
  { title: 'SAP BW/4HANA', description: 'Werkzeuge zur Reporting, Analyse und Interpretation von Unternehmensdaten für marktgerechtes Agieren.' },
];
---

<section class="py-32 bg-white" id="core-competencies">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16">
      <h2 class="text-4xl font-normal text-slate-900 mb-4 tracking-tight">Unsere SAP Kernkompetenzen</h2>
      <div class="h-1 w-20 bg-primary rounded-full mb-2"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
      {competencies.map((comp, i) => (
        <div
          data-animate
          data-animate-delay={i > 0 ? String(Math.min(i, 6)) : undefined}
          class="space-y-3"
        >
          <h3 class="text-lg font-normal text-slate-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            {comp.title}
          </h3>
          <p class="text-sm text-slate-500 leading-relaxed">{comp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
