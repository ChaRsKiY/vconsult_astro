---
import type { Lang } from '@/i18n/utils';
import { useTranslations, localePath } from '@/i18n/utils';
import type { SectionContent } from '@/lib/content';

interface Props {
  lang?: Lang;
  cms?: SectionContent;
}

const { lang = 'de', cms } = Astro.props;
const t = useTranslations(lang);

const title = cms?.title ?? t.cta.title;
const subtitle = cms?.subtitle ?? t.cta.subtitle;
const ctaPrimary = cms?.ctaPrimary ?? t.cta.ctaPrimary;
const ctaSecondary = cms?.ctaSecondary ?? t.cta.ctaSecondary;
---

<section class="relative bg-white py-32 overflow-hidden">
  <div class="absolute top-0 right-0 -mr-20 -mt-20 h-96 w-96 rounded-full bg-primary/5 blur-3xl"></div>
  <div class="mx-auto max-w-7xl px-6 text-center relative z-10">
    <h2 data-animate class="text-4xl md:text-5xl font-normal text-slate-900">
      {title}
    </h2>
    <p data-animate data-animate-delay="1" class="mx-auto mt-8 max-w-2xl text-lg text-slate-600">
      {subtitle}
    </p>
    <div data-animate data-animate-delay="2" class="mt-12 flex flex-wrap justify-center gap-6">
      <a href={localePath('/kontakt', lang)} class="rounded-xl font-bold transition-all shadow-lg inline-flex items-center justify-center gap-2 bg-slate-900 text-white shadow-none hover:bg-slate-800 px-8 py-4 text-base">
        {ctaPrimary}
      </a>
      <a href={localePath('/leistungen', lang)} class="rounded-xl font-bold transition-all inline-flex items-center justify-center gap-2 border border-primary text-primary hover:bg-primary/5 bg-white shadow-none px-8 py-4 text-base">
        {ctaSecondary}
      </a>
    </div>
  </div>
</section>
