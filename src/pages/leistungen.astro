---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { useTranslations, localePath } from '@/i18n/utils';
import { fetchContent } from '@/lib/content';
import type { SectionContent } from '@/lib/content';

const lang = 'de' as const;
const t = useTranslations(lang);
const cms = await fetchContent(lang);
const c: SectionContent = cms.leistungen ?? {};

const title           = c.title;
const description     = c.description;
const breadcrumb      = c.breadcrumb;
const outsourcingTitle= c.outsourcingTitle;
const outsourcingDesc = c.outsourcingDesc;
const vconsupportLabel= c.vconsupportLabel;
const vconsupportTitle= c.vconsupportTitle;
const downloadLabels  = [1,2,3].map(n => c[`download${n}`]);
const downloadFiles   = [
  '/downloads/marketing-one-Pager-general.pdf',
  '/downloads/marketing-one-Pager-Aussenhandel.pdf',
  '/downloads/marketing-one-Pager-clean-system-1.pdf',
];
const downloads = downloadLabels.map((label, i) => ({ label, file: downloadFiles[i] }));
const sapTitle        = c.sapTitle;
const sapDesc         = c.sapDesc;
const schwerpunkte    = c.schwerpunkteLabel;
const competencies    = [1,2,3,4,5].map(n => c[`competency${n}`]);
const mBaITQuote      = c.mBaITQuote;
const mBaITHighlight  = c.mBaITHighlight;
const mBaITText       = c.mBaITText;
const philosophieLink = c.philosophieLink;
const footer          = cms.footer ?? {};
---

<BaseLayout title="Unsere Leistungen - vconsult" description="Outsourcing und holistische SAP Logistik-Optimierung" lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title={title}
      description={description}
      breadcrumbs={[{ label: breadcrumb }]}
      lang={lang}
    />

    <!-- Service Cards -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

          <!-- Card 1: Outsourcing -->
          <div data-animate class="rounded-3xl border border-border-light bg-neutral-soft p-10 flex flex-col gap-8">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-sm text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <div>
              <h2 class="text-3xl font-normal text-slate-900 mb-4">{outsourcingTitle}</h2>
              <p class="text-slate-600 leading-relaxed">{outsourcingDesc}</p>
            </div>
            <div class="bg-white rounded-2xl border border-border-light p-6 flex-grow">
              <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">{vconsupportLabel}</p>
              <h3 class="text-lg font-normal text-slate-900 mb-4">{vconsupportTitle}</h3>
              <ul class="space-y-3">
                {downloads.map(item => (
                  <li>
                    <a
                      href={item.file}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-3 group"
                    >
                      <div class="flex-shrink-0 h-8 w-8 rounded-lg bg-primary/8 flex items-center justify-center group-hover:bg-primary/15 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M12 17v-6"/><path d="m9 14 3 3 3-3"/></svg>
                      </div>
                      <span class="text-sm text-slate-700 group-hover:text-primary transition-colors">
                        {item.label} <span class="text-slate-400">{t.leistungen.downloadPdf}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Card 2: SAP Logistik -->
          <div data-animate data-animate-delay="1" class="rounded-3xl border border-border-light bg-neutral-soft p-10 flex flex-col gap-8">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-sm text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 21H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/><path d="M22 3h-6v12h6V3Z"/><path d="M16 8h6"/><path d="M16 12h6"/><path d="M6 14H4"/><path d="M6 18H4"/><path d="M10 14H8"/><path d="M10 18H8"/></svg>
            </div>
            <div>
              <h2 class="text-3xl font-normal text-slate-900 mb-4">{sapTitle}</h2>
              <p class="text-slate-600 leading-relaxed">{sapDesc}</p>
            </div>
            <div class="flex-grow">
              <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">{schwerpunkte}</p>
              <ul class="space-y-2.5">
                {competencies.map(item => (
                  <li class="flex items-start gap-3 text-sm text-slate-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Enterprise AI Teaser -->
    <section class="py-16 bg-white border-t border-border-light">
      <div class="max-w-7xl mx-auto px-6">
        <div data-animate class="rounded-3xl border border-primary/20 bg-primary/[0.03] p-8 md:p-12 flex flex-col md:flex-row md:items-center gap-8">
          <div class="flex-grow">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Ein Produkt der vconsult Gruppe</p>
            <h2 class="text-2xl font-normal text-slate-900 mb-3 tracking-tight">Enterprise AI mit SAP-Integration</h2>
            <p class="text-slate-600 leading-relaxed max-w-2xl">
              Enterprisebrain verbindet KI direkt mit Ihren SAP-Systemen — für Echtzeit-Analysen, Prozessautomatisierung und intelligenten Support. Bereits mit 6+ aktiven Use Cases live bei Kunden im Einsatz.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row md:flex-col gap-3 shrink-0">
            <a
              href={localePath('/leistungen/enterprise-ai', lang)}
              class="rounded-xl font-bold transition-all inline-flex items-center justify-center gap-2 bridge-gradient text-white shadow-primary/20 shadow-lg px-6 py-3 text-sm hover:opacity-90 whitespace-nowrap"
            >
              Mehr erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="https://enterprisebrain.eu"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xl font-bold transition-all inline-flex items-center justify-center gap-2 border border-border-light bg-white text-slate-900 hover:bg-neutral-soft px-6 py-3 text-sm whitespace-nowrap"
            >
              enterprisebrain.eu
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- mBaIT Quote -->
    <section class="py-20 bg-neutral-soft border-t border-border-light">
      <div data-animate class="max-w-3xl mx-auto px-6 text-center">
        <div class="inline-block w-10 h-0.5 bg-primary mb-8"></div>
        <p class="text-2xl font-normal text-slate-900 leading-relaxed">
          {mBaITQuote} <em class="not-italic text-transparent bg-clip-text bridge-gradient">{mBaITHighlight}</em> {mBaITText}
        </p>
        <div class="mt-10">
          <a href={localePath('/philosophie', lang)} class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:gap-3 transition-all">
            {philosophieLink}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} cms={footer} />
</BaseLayout>
