---
import { marked } from 'marked';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import { useTranslations, localePath } from '@/i18n/utils';
import { fetchArticles, fetchContent } from '@/lib/content';
import type { ArticleItem } from '@/lib/content';

export async function getStaticPaths() {
  const articles = await fetchArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: ArticleItem;
}

const { article } = Astro.props;
const lang = 'en' as const;
const t = useTranslations(lang);
const cms = await fetchContent(lang);

const formattedDate = new Date(article.date).toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const contentHtml = article.content ? await marked.parse(article.content) : '';
---

<BaseLayout title={`${article.title} - vconsult`} description={article.shortDescription} lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main class="bg-white min-h-screen pb-24">
    <!-- Header -->
    <div class="bg-neutral-soft pt-32 pb-16 border-b border-border-light">
      <div class="max-w-4xl mx-auto px-6">
        <a href={localePath('/news', lang)} class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          {t.blog.backToAll}
        </a>

        <div class="flex items-center gap-4 mb-6">
          <span class="rounded-full bg-primary/10 text-primary px-3 py-1 text-xs font-bold uppercase tracking-wider">
            {article.category}
          </span>
          <span class="flex items-center gap-2 text-sm text-slate-500 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            {formattedDate}
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl font-normal text-slate-900 mb-8">
          {article.title}
        </h1>

        <div class="flex flex-wrap gap-2">
          {article.tags.map(tag => (
            <span class="flex items-center gap-1 text-sm font-medium text-slate-600 bg-white border border-border-light px-3 py-1.5 rounded-lg shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Hero Image -->
    {article.image && (
      <div class="max-w-5xl mx-auto px-6 -mt-8 relative z-10 mb-16">
        <div class="relative aspect-[21/9] w-full rounded-2xl overflow-hidden shadow-xl border border-border-light bg-slate-100">
          <img src={article.image} alt={article.title} class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>
    )}

    <!-- Article Content -->
    <div class="max-w-3xl mx-auto px-6">
      <article
        class="prose prose-slate prose-lg lg:prose-xl prose-headings:font-normal prose-headings:tracking-tight prose-a:text-primary hover:prose-a:text-secondary prose-img:rounded-xl"
        set:html={contentHtml}
      />
    </div>
  </main>
  <Footer lang={lang} cms={cms.footer} />
</BaseLayout>
