---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { fetchContent, type SectionContent } from '@/lib/content';

const lang = 'en' as const;
const cms = await fetchContent(lang);
const c: SectionContent = cms.philosophiePage ?? {};
const footer = cms.footer ?? {};

const title          = c.title;
const description    = c.description;
const breadcrumb     = c.breadcrumb;
const p1             = c.p1;
const quoteTitle     = c.quoteTitle;
const quoteText      = c.quoteText;
const p2             = c.p2;
const cta            = c.cta;
const workflow1Title = c.workflow1Title;
const workflow1Desc  = c.workflow1Desc;
const workflow2Title = c.workflow2Title;
const workflow2Desc  = c.workflow2Desc;
const workflow3Title = c.workflow3Title;
const workflow3Desc  = c.workflow3Desc;
---

<BaseLayout title="Our Philosophy - vconsult" description="Are intensive IT investments generating the desired success?" lang={lang}>
  <Navbar currentPath={Astro.url.pathname} lang={lang} />
  <main>
    <PageHeader
      title={title}
      description={description}
      breadcrumbs={[{ label: breadcrumb }]}
      lang={lang}
    />

    <!-- Introduction -->
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-slate-600 leading-relaxed space-y-8 text-lg">
        <div data-animate>
          <p>{p1}</p>
        </div>
        <div data-animate data-animate-delay="1" class="p-8 md:p-12 rounded-3xl bg-neutral-soft border-l-4 border-primary">
          <h2 class="text-3xl font-normal tracking-tight text-slate-900 mb-6 uppercase">{quoteTitle}</h2>
          <p class="text-lg">{quoteText}</p>
        </div>
        <div data-animate data-animate-delay="2">
          <p>{p2}</p>
          <p class="font-medium text-slate-900 text-xl border-t border-border-light pt-8 mt-12 text-center">
            {cta}
          </p>
        </div>
      </div>
    </section>

    <!-- Visual Workflow -->
    <section class="py-32 bg-neutral-soft text-slate-900 border-t border-border-light">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div data-animate class="flex flex-col items-center text-center">
            <div class="w-20 h-20 rounded-full bg-white shadow-sm border border-border-light flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
            </div>
            <h3 class="text-xl font-normal mb-4">{workflow1Title}</h3>
            <p class="text-slate-600">{workflow1Desc}</p>
          </div>
          <div data-animate data-animate-delay="1" class="flex flex-col items-center text-center">
            <div class="w-24 h-24 rounded-full bridge-gradient flex items-center justify-center mb-6 shadow-xl shadow-primary/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9a2 2 0 0 0-2 2v2c0 1.1.9 2 2 2h4"/><path d="M20 9a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-4"/><path d="M12 4v16"/><path d="M8 4h8"/><path d="M8 20h8"/></svg>
            </div>
            <h3 class="text-xl font-normal mb-4">{workflow2Title}</h3>
            <p class="text-slate-600">{workflow2Desc}</p>
          </div>
          <div data-animate data-animate-delay="2" class="flex flex-col items-center text-center">
            <div class="w-20 h-20 rounded-full bg-white shadow-sm border border-border-light flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h3 class="text-xl font-normal mb-4">{workflow3Title}</h3>
            <p class="text-slate-600">{workflow3Desc}</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} cms={footer} />
</BaseLayout>
