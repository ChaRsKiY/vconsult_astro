---
interface Props {
  label: string;
  id: string;
  placeholder?: string;
  class?: string;
  required?: boolean;
}

const { label, id, placeholder, class: className = '', required } = Astro.props;
---

<div class="flex flex-col gap-2">
  <label for={id} class="text-sm font-bold text-slate-900">{label}</label>
  <textarea
    id={id}
    name={id}
    placeholder={placeholder}
    required={required}
    class={`w-full min-h-[150px] resize-y rounded-xl border border-border-light bg-neutral-soft px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all ${className}`}
  ></textarea>
</div>
